# Template only: copy to `server/.env` (real secrets). That file is gitignored.
# `.env.example` is safe to commit — it has no real passwords or API keys.
# On Render: set the same variable names in the Web Service → Environment tab.

# PostgreSQL (Render often needs ?sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

JWT_SECRET="generate-a-long-random-string"
# Optional separate secret for OTP HMAC (defaults to JWT_SECRET)
# OTP_PEPPER="another-long-random-string"

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# Bootstrap staff admin (no DB row). Used for first console access + recovery.
ADMIN_BOOTSTRAP_EMAIL="admin@yourcompany.com"
# Legacy: compared via SHA-256 timing-safe check (rotate away when possible).
ADMIN_BOOTSTRAP_PASSWORD="change-me-immediately"
# Preferred: bcrypt hash of bootstrap password (e.g. from Node: bcrypt.hashSync('your-strong-pass', 11))
# ADMIN_BOOTSTRAP_PASSWORD_BCRYPT="$2a$11$..."

# Google — server verifies ID tokens (same Web client ID as Vite VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=""

# Email (Nodemailer) — OTP for verify-email and password change
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
# Gmail app passwords may include spaces; the server strips them automatically.
SMTP_PASS=""
MAIL_FROM="TrustedHome <noreply@yourdomain.com>"

# Server
PORT=4000
# No trailing slash. Comma-separated for multiple (prod + Vercel preview URLs).
# Example: https://trust-homes.vercel.app,https://trust-homes-git-main-xxx.vercel.app
CLIENT_ORIGIN="http://localhost:5173"
